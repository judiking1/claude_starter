#!/usr/bin/env bash
#
# Claude Code Starter — 프로젝트 초기화 스크립트
#
# 현재 디렉토리에 프로젝트 템플릿 파일들을 복사합니다.
# (CLAUDE.md, .claude/rules/, docs/)
#
# 사용법:
#   cd ~/projects/my-new-project
#   ~/.claude/skills/claude_starter/init
#
# 또는 프로젝트 이름을 지정:
#   ~/.claude/skills/claude_starter/init my-project

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/template"
TARGET_DIR="$(pwd)"
PROJECT_NAME="${1:-}"

# 템플릿 디렉토리 확인
if [ ! -d "$TEMPLATE_DIR" ]; then
    echo "Error: 템플릿 디렉토리를 찾을 수 없습니다: $TEMPLATE_DIR"
    echo "setup을 먼저 실행했는지 확인하세요."
    exit 1
fi

echo ""
echo "=== Claude Code Starter — 프로젝트 초기화 ==="
echo ""
echo "대상 디렉토리: $TARGET_DIR"
echo ""

# 기존 파일 충돌 확인
CONFLICTS=""
if [ -f "$TARGET_DIR/CLAUDE.md" ]; then
    CONFLICTS="$CONFLICTS CLAUDE.md"
fi
if [ -d "$TARGET_DIR/.claude/rules" ]; then
    CONFLICTS="$CONFLICTS .claude/rules/"
fi

if [ -n "$CONFLICTS" ]; then
    echo "경고: 다음 파일이 이미 존재합니다:$CONFLICTS"
    echo ""
    read -p "덮어쓰시겠습니까? (y/N): " CONFIRM
    if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
        echo "취소되었습니다."
        exit 0
    fi
    echo ""
fi

# 파일 복사
echo "파일 복사 중..."

# CLAUDE.md
cp "$TEMPLATE_DIR/CLAUDE.md" "$TARGET_DIR/CLAUDE.md"
echo "  CLAUDE.md"

# .claude/rules/
mkdir -p "$TARGET_DIR/.claude/rules"
cp "$TEMPLATE_DIR/.claude/launch.json" "$TARGET_DIR/.claude/launch.json"
echo "  .claude/launch.json"
cp "$TEMPLATE_DIR/.claude/rules/"*.md "$TARGET_DIR/.claude/rules/"
echo "  .claude/rules/ (7개 규칙 파일)"

# docs/
mkdir -p "$TARGET_DIR/docs/adr"
cp "$TEMPLATE_DIR/docs/"*.md "$TARGET_DIR/docs/"
cp "$TEMPLATE_DIR/docs/adr/"*.md "$TARGET_DIR/docs/adr/"
echo "  docs/ (가이드 + ADR 템플릿)"

# 프로젝트 이름이 지정되었으면 CLAUDE.md에 자동 반영
if [ -n "$PROJECT_NAME" ]; then
    if command -v sed &>/dev/null; then
        sed -i "s/\[PROJECT_NAME\]/$PROJECT_NAME/g" "$TARGET_DIR/CLAUDE.md" 2>/dev/null || \
        sed -i '' "s/\[PROJECT_NAME\]/$PROJECT_NAME/g" "$TARGET_DIR/CLAUDE.md" 2>/dev/null || true
        echo ""
        echo "프로젝트 이름 '$PROJECT_NAME'이 CLAUDE.md에 반영되었습니다."
    fi
fi

echo ""
echo "=== 초기화 완료! ==="
echo ""
echo "다음 단계:"
if [ -z "$PROJECT_NAME" ]; then
    echo "  1. CLAUDE.md에서 [PROJECT_NAME]과 [PROJECT_DESCRIPTION]을 수정하세요"
    echo "  2. claude 실행"
    echo "  3. /project-kickoff <프로젝트이름>"
else
    echo "  1. CLAUDE.md에서 [PROJECT_DESCRIPTION]을 수정하세요"
    echo "  2. claude 실행"
    echo "  3. /project-kickoff $PROJECT_NAME"
fi
echo ""
echo "스킬은 글로벌로 설치되어 있어서 별도 복사 없이 바로 사용 가능합니다."
echo "  /ship, /review, /qa, /investigate, /careful, /retro 등"
echo ""
