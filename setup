#!/usr/bin/env bash
#
# Claude Code Starter — 글로벌 설치 스크립트
#
# 이 스크립트는 PC에 한 번만 실행하면 됩니다.
# 설치 후 어떤 프로젝트에서든 /ship, /qa, /review 등의 스킬을 사용할 수 있습니다.
#
# 사용법:
#   git clone --depth 1 https://github.com/judiking1/claude_starter.git ~/.claude/skills/claude_starter
#   cd ~/.claude/skills/claude_starter && ./setup

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="$HOME/.claude/skills/claude_starter"

echo ""
echo "=== Claude Code Starter Setup ==="
echo ""

# 설치 경로 확인
if [ "$SCRIPT_DIR" != "$INSTALL_DIR" ]; then
    echo "이 레포가 ~/.claude/skills/claude_starter 에 있지 않습니다."
    echo "현재 위치: $SCRIPT_DIR"
    echo ""
    echo "올바른 설치 방법:"
    echo "  git clone --depth 1 https://github.com/judiking1/claude_starter.git ~/.claude/skills/claude_starter"
    echo "  cd ~/.claude/skills/claude_starter && ./setup"
    echo ""
    exit 1
fi

# 스킬 목록 확인
SKILL_COUNT=0
for dir in "$INSTALL_DIR"/*/; do
    if [ -f "${dir}SKILL.md" ]; then
        SKILL_COUNT=$((SKILL_COUNT + 1))
    fi
done

echo "설치 위치: $INSTALL_DIR"
echo "발견된 스킬: ${SKILL_COUNT}개"
echo ""

# 스킬 목록 출력
echo "사용 가능한 스킬:"
echo "  /init             — 프로젝트 템플릿 초기화 (CLAUDE.md, rules, docs)"
echo "  /project-kickoff  — 새 프로젝트 시작 (컨셉, 디자인, 기술 결정)"
echo "  /plan-review      — 코딩 전 아키텍처 리뷰"
echo "  /team-lead        — 병렬 에이전트 오케스트레이션"
echo "  /design-system    — 디자인 시스템 구축"
echo "  /review           — 코드 리뷰 (Specialist Dispatch)"
echo "  /qa               — QA 테스트 (Health Score)"
echo "  /ship             — 자동 배포 파이프라인"
echo "  /investigate      — 체계적 디버깅"
echo "  /careful          — 위험 명령 가드레일"
echo "  /retro            — 주간 회고"
echo "  /learn            — 세션 간 학습 관리"
echo ""

echo "설치 완료!"
echo ""
echo "=== 다음 단계 ==="
echo ""
echo "새 프로젝트를 시작하려면:"
echo "  cd ~/projects/my-project"
echo "  claude"
echo "  > /init my-project              ← 템플릿 초기화"
echo "  > /project-kickoff my-project   ← 프로젝트 설정 시작"
echo ""
